{
  "name": "header-editor-pro-free",
  "version": "1.4.1",
  "description": "Professional HTTP header editor for web developers, API testing, and debugging - completely free with unlimited profiles",
  "main": "src/popup/popup.js",
  "scripts": {
    "dev": "rspack build --mode development --watch",
    "build": "rspack build --mode production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "echo 'Linting not configured yet'",
    "typecheck": "echo 'TypeScript not configured yet'",
    "get-version": "node -p \"JSON.parse(require('fs').readFileSync('src/manifest.json', 'utf8')).version\"",
    "create-source-package": "VERSION=$(npm run get-version --silent) && zip -r \"header-editor-pro-free-source-v${VERSION}.zip\" src/ package*.json rspack.config.js BUILD_INSTRUCTIONS.md README.md",
    "package": "npm run build && npm run create-source-package && VERSION=$(npm run get-version --silent) && cd dist && zip -r \"../header-editor-pro-free-extension-v${VERSION}.zip\" .",
    "clean": "rm -rf dist/ && rm -f *.zip",
    "release": "bash scripts/release.sh"
  },
  "keywords": [
    "chrome-extension",
    "firefox-addon",
    "http-headers",
    "web-development",
    "api-testing",
    "browser-extension"
  ],
  "author": "testacode.com",
  "license": "MIT",
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@jest/globals": "^30.0.5",
    "@rspack/cli": "^1.0.14",
    "@rspack/core": "^1.0.14",
    "@types/chrome": "^0.1.4",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.0.5",
    "css-loader": "^7.1.2",
    "jest": "^30.0.5",
    "jest-chrome": "^0.8.0",
    "jest-environment-jsdom": "^30.0.5",
    "webpack-merge": "^6.0.1"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
