{
  "name": "Header Editor Pro - Free",
  "description": "Professional HTTP header editor for web developers, API testing, and debugging - completely free with unlimited profiles",
  "version": "1.0.5",
  "manifest_version": 3,
  "permissions": ["declarativeNetRequest", "storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.jpeg"
  },
  "icons": {
    "16": "icons/icon16.jpeg",
    "32": "icons/icon32.jpeg",
    "48": "icons/icon48.jpeg",
    "128": "icons/icon128.jpeg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "header-editor-pro@testacode.com",
      "strict_min_version": "101.0"
    }
  }
}
