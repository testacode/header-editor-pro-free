{
  "name": "Header Editor Pro - Free",
  "description": "Professional HTTP header editor for web developers, API testing, and debugging - completely free with unlimited profiles",
  "version": "2.0.1",
  "manifest_version": 3,
  "permissions": ["declarativeNetRequest", "storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "js/background.js",
    "scripts": ["js/background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "header-editor-pro@testacode.com",
      "strict_min_version": "101.0"
    }
  },
  "homepage_url": "https://github.com/testacode/header-editor-pro-free",
  "author": "testacode",
  "privacy_policy": "https://testacode.github.io/header-editor-pro-free/privacy.html"
}